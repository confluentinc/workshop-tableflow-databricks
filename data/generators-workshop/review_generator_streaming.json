{
    "name": "review_generator_streaming",
    "table": "cdc.hotel_reviews",
    "connection": "postgres",
    "localConfigs": {
        "maxEvents": 262,
        "throttleMs": {
            "_gen": "uniformDistribution",
            "bounds": [
                300000,
                360000
            ]
        }
    },
    "varsOnce": {
        "currentTimeInMs": {
            "_gen": "now"
        },
        "oneStarTexts": {
            "_gen": "loadJsonFile",
            "file": "/home/data/generators/content/review_text_choices_1_star.json"
        },
        "twoStarTexts": {
            "_gen": "loadJsonFile",
            "file": "/home/data/generators/content/review_text_choices_2_star.json"
        },
        "threeStarTexts": {
            "_gen": "loadJsonFile",
            "file": "/home/data/generators/content/review_text_choices_3_star.json"
        },
        "fourStarTexts": {
            "_gen": "loadJsonFile",
            "file": "/home/data/generators/content/review_text_choices_4_star.json"
        },
        "fiveStarTexts": {
            "_gen": "loadJsonFile",
            "file": "/home/data/generators/content/review_text_choices_5_star.json"
        }
    },
    "row": {
        "review_id": {
            "_gen": "sequentialString",
            "startingFrom": 560001000,
            "expr": "R~d",
            "pgHint": "VARCHAR(50) PRIMARY KEY"
        },
        "booking_id": {
            "_gen": "lookup",
            "name": "booking_generator_streaming",
            "path": [
                "row",
                "booking_id"
            ],
            "pgHint": "VARCHAR(50)"
        },
        "review_rating": {
            "_gen": "weightedOneOf",
            "choices": [
                {
                    "weight": 10,
                    "value": 1
                },
                {
                    "weight": 20,
                    "value": 2
                },
                {
                    "weight": 30,
                    "value": 3
                },
                {
                    "weight": 25,
                    "value": 4
                },
                {
                    "weight": 15,
                    "value": 5
                }
            ],
            "pgHint": "INTEGER"
        },
        "review_text": {
            "_gen": "weightedOneOf",
            "choices": [
                {
                    "weight": 10,
                    "value": {
                        "_gen": "oneOf",
                        "choices": {
                            "_gen": "var",
                            "var": "oneStarTexts"
                        }
                    }
                },
                {
                    "weight": 20,
                    "value": {
                        "_gen": "oneOf",
                        "choices": {
                            "_gen": "var",
                            "var": "twoStarTexts"
                        }
                    }
                },
                {
                    "weight": 30,
                    "value": {
                        "_gen": "oneOf",
                        "choices": {
                            "_gen": "var",
                            "var": "threeStarTexts"
                        }
                    }
                },
                {
                    "weight": 25,
                    "value": {
                        "_gen": "oneOf",
                        "choices": {
                            "_gen": "var",
                            "var": "fourStarTexts"
                        }
                    }
                },
                {
                    "weight": 15,
                    "value": {
                        "_gen": "oneOf",
                        "choices": {
                            "_gen": "var",
                            "var": "fiveStarTexts"
                        }
                    }
                }
            ],
            "pgHint": "TEXT"
        },
        "created_at": {
            "_gen": "now",
            "serialize": {
                "type": "postgresTimestamp"
            },
            "pgHint": "TIMESTAMP"
        }
    }
}
