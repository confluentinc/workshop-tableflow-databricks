{
    "name": "customer_updates_historical",
    "table": "cdc.customer",
    "connection": "postgres",
    "op": "update",
    "localConfigs": {
        "maxEvents": 500
    },
    "varsOnce": {
        "currentTimeInMs": {
            "_gen": "now"
        },
        "baseTimeInMs": {
            "_gen": "math",
            "expr": "currentTimeInMs - 5184000000"
        }
    },
    "vars": {
        "eventIndex": {
            "_gen": "sequentialInteger",
            "startingFrom": 0
        },
        "eventIntervalMs": {
            "_gen": "uniformDistribution",
            "bounds": [
                86400000,
                172800000
            ],
            "decimals": 0
        },
        "update_time": {
            "_gen": "min",
            "args": [
                {
                    "_gen": "math",
                    "expr": "baseTimeInMs + (eventIndex * eventIntervalMs)",
                    "decimals": 0
                },
                {
                    "_gen": "var",
                    "var": "currentTimeInMs"
                }
            ]
        }
    },
    "row": {
        "updated_at": {
            "_gen": "var",
            "var": "update_time",
            "serialize": {
                "type": "postgresTimestamp"
            }
        }
    },
    "where": {
        "customer_id": {
            "_gen": "sequentialString",
            "startingFrom": 310000000,
            "expr": "C~d"
        }
    }
}
