{
    "name": "hotel_generator_streaming",
    "table": "cdc.hotel",
    "connection": "postgres",
    "op": "update",
    "localConfigs": {
        "throttleMs": {
            "_gen": "uniformDistribution",
            "bounds": [
                20000,
                40000
            ]
        }
    },
    "vars": {
        "room_capacity": {
            "_gen": "normalDistribution",
            "mean": 250,
            "sd": 50,
            "decimals": 0,
            "clamp": [
                150,
                500
            ]
        },
        "low_occupancy_rate": {
            "_gen": "uniformDistribution",
            "bounds": [
                0.10,
                0.20
            ],
            "decimals": 2
        }
    },
    "row": {
        "updated_at": {
            "_gen": "now",
            "serialize": {
                "type": "postgresTimestamp"
            }
        },
        "available_rooms": {
            "_gen": "math",
            "expr": "room_capacity * low_occupancy_rate",
            "decimals": 0
        }
    },
    "where": {
        "hotel_id": {
            "_gen": "oneOf",
            "choices": [
                "H21000000",
                "H21000001",
                "H21000002",
                "H21000003",
                "H21000004",
                "H21000005",
                "H21000006",
                "H21000007",
                "H21000008",
                "H21000009",
                "H21000010",
                "H21000011",
                "H21000012",
                "H21000013",
                "H21000014",
                "H21000015",
                "H21000016",
                "H21000017",
                "H21000018",
                "H21000019",
                "H21000020",
                "H21000021",
                "H21000022",
                "H21000023",
                "H21000024",
                "H21000025",
                "H21000026",
                "H21000027",
                "H21000028",
                "H21000029"
            ]
        }
    }
}
