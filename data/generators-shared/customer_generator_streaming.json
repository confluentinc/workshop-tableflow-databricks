{
    "name": "customer_generator_streaming",
    "table": "cdc.customer",
    "connection": "postgres",
    "op": "update",
    "localConfigs": {
        "throttleMs": {
            "_gen": "uniformDistribution",
            "bounds": [
                20000,
                40000
            ]
        }
    },
    "row": {
        "rewards_points": {
            "_gen": "uniformDistribution",
            "bounds": [100, 2000],
            "decimals": 0
        },
        "updated_at": {
            "_gen": "now",
            "serialize": {
                "type": "postgresTimestamp"
            }
        }
    },
    "where": {
        "customer_id": {
            "_gen": "lookup",
            "name": "customer_generator_historical",
            "path": ["row", "customer_id"]
        }
    }
}
